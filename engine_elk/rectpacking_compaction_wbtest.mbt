}

///|
test "rectpacking compaction: place stack next to multiple block stack" {
  let root = ElkNode::new("root")
  let n1 = ElkNode::with_size("n1", 30.0, 100.0)
  let n2 = ElkNode::with_size("n2", 30.0, 10.0)
  let n3 = ElkNode::with_size("n3", 30.0, 10.0)
  let n4 = ElkNode::with_size("n4", 30.0, 85.0)
  let n5 = ElkNode::with_size("n5", 30.0, 85.0)
  let n6 = ElkNode::with_size("n6", 30.0, 30.0)
  root.add_child(n1)
  root.add_child(n2)
  root.add_child(n3)
  root.add_child(n4)
  root.add_child(n5)
  root.add_child(n6)
  elk_rect_packing_layout(root, rectpacking_target_width_options(135.0, 5.0))
  assert_true((root.width - 135.0).abs() < 0.0001)
  assert_true((root.height - 100.0).abs() < 0.0001)
  assert_true((n1.x - 0.0).abs() < 0.0001)
  assert_true((n1.y - 0.0).abs() < 0.0001)
  assert_true((n2.x - 35.0).abs() < 0.0001)
  assert_true((n2.y - 0.0).abs() < 0.0001)
  assert_true((n3.x - 70.0).abs() < 0.0001)
  assert_true((n3.y - 0.0).abs() < 0.0001)
  assert_true((n4.x - 35.0).abs() < 0.0001)
  assert_true((n4.y - 15.0).abs() < 0.0001)
  assert_true((n5.x - 70.0).abs() < 0.0001)
  assert_true((n5.y - 15.0).abs() < 0.0001)
  assert_true((n6.x - 105.0).abs() < 0.0001)
  assert_true((n6.y - 0.0).abs() < 0.0001)
}
