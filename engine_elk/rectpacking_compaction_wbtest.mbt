///|
fn rectpacking_target_width_options(
  target_width : Double,
  spacing : Double,
) -> LayoutOptions {
  let custom : Map[String, PropertyValue] = {
    "org.eclipse.elk.rectpacking.widthApproximation.strategy": PropertyValue::Enum(
      "TARGET_WIDTH",
    ),
    "org.eclipse.elk.rectpacking.widthApproximation.targetWidth": PropertyValue::Double(
      target_width,
    ),
  }
  {
    ..LayoutOptions::new(),
    aspect_ratio: Some(1.3),
    node_node_spacing: Some(spacing),
    padding: Some(ElkPadding::uniform(0.0)),
    custom: Some(custom),
  }
}

///|
test "rectpacking compaction: place block from next row on top" {
  let root = ElkNode::new("root")
  let n1 = ElkNode::with_size("n1", 30.0, 70.0)
  let n2 = ElkNode::with_size("n2", 30.0, 10.0)
  let n3 = ElkNode::with_size("n3", 30.0, 10.0)
  let n4 = ElkNode::with_size("n4", 30.0, 50.0)
  let n5 = ElkNode::with_size("n5", 30.0, 50.0)
  let n6 = ElkNode::with_size("n6", 100.0, 10.0)
  let _n7 = ElkNode::with_size("n7", 100.0, 10.0)
  root.add_child(n1)
  root.add_child(n2)
  root.add_child(n3)
  root.add_child(n4)
  root.add_child(n5)
  root.add_child(n6)
  root.add_child(_n7)
  elk_rect_packing_layout(root, rectpacking_target_width_options(110.0, 10.0))
  assert_true((root.width - 110.0).abs() < 0.0001)
  assert_true((root.height - 110.0).abs() < 0.0001)
  assert_true((n1.x - 0.0).abs() < 0.0001)
  assert_true((n1.y - 0.0).abs() < 0.0001)
  assert_true((n2.x - 40.0).abs() < 0.0001)
  assert_true((n2.y - 0.0).abs() < 0.0001)
  assert_true((n3.x - 80.0).abs() < 0.0001)
  assert_true((n3.y - 0.0).abs() < 0.0001)
  assert_true((n4.x - 40.0).abs() < 0.0001)
  assert_true((n4.y - 20.0).abs() < 0.0001)
  assert_true((n5.x - 80.0).abs() < 0.0001)
  assert_true((n5.y - 20.0).abs() < 0.0001)
  assert_true((n6.x - 0.0).abs() < 0.0001)
  assert_true((n6.y - 80.0).abs() < 0.0001)
}

///|
test "rectpacking compaction: place block from next row on top does not work" {
  let root = ElkNode::new("root")
  let n1 = ElkNode::with_size("n1", 30.0, 70.0)
  let n2 = ElkNode::with_size("n2", 40.0, 10.0)
  let n3 = ElkNode::with_size("n3", 30.0, 10.0)
  let n4 = ElkNode::with_size("n4", 30.0, 50.0)
  let n5 = ElkNode::with_size("n5", 30.0, 50.0)
  let _n6 = ElkNode::with_size("n6", 100.0, 10.0)
  let _n7 = ElkNode::with_size("n7", 100.0, 10.0)
  root.add_child(n1)
  root.add_child(n2)
  root.add_child(n3)
  root.add_child(n4)
  root.add_child(n5)
  root.add_child(_n6)
  root.add_child(_n7)
  elk_rect_packing_layout(root, rectpacking_target_width_options(110.0, 10.0))
  assert_true((root.width - 100.0).abs() < 0.0001)
  assert_true((root.height - 170.0).abs() < 0.0001)
  assert_true((n1.x - 0.0).abs() < 0.0001)
  assert_true((n1.y - 0.0).abs() < 0.0001)
  assert_true((n2.x - 40.0).abs() < 0.0001)
  assert_true((n2.y - 0.0).abs() < 0.0001)
  assert_true((n3.x - 40.0).abs() < 0.0001)
  assert_true((n3.y - 20.0).abs() < 0.0001)
  assert_true((n4.x - 0.0).abs() < 0.0001)
  assert_true((n4.y - 80.0).abs() < 0.0001)
  assert_true((n5.x - 40.0).abs() < 0.0001)
  assert_true((n5.y - 80.0).abs() < 0.0001)
}

///|
test "rectpacking compaction: absorb block" {
  let root = ElkNode::new("root")
  let n1 = ElkNode::with_size("n1", 30.0, 70.0)
  let n2 = ElkNode::with_size("n2", 30.0, 30.0)
  let n3 = ElkNode::with_size("n3", 30.0, 30.0)
  let n4 = ElkNode::with_size("n4", 30.0, 30.0)
  let n5 = ElkNode::with_size("n5", 30.0, 30.0)
  let n6 = ElkNode::with_size("n6", 100.0, 10.0)
  let _n7 = ElkNode::with_size("n7", 100.0, 10.0)
  root.add_child(n1)
  root.add_child(n2)
  root.add_child(n3)
  root.add_child(n4)
  root.add_child(n5)
  root.add_child(n6)
  root.add_child(_n7)
  elk_rect_packing_layout(root, rectpacking_target_width_options(110.0, 10.0))
  assert_true((root.width - 110.0).abs() < 0.0001)
  assert_true((root.height - 110.0).abs() < 0.0001)
  assert_true((n1.x - 0.0).abs() < 0.0001)
  assert_true((n1.y - 0.0).abs() < 0.0001)
  assert_true((n2.x - 40.0).abs() < 0.0001)
  assert_true((n2.y - 0.0).abs() < 0.0001)
  assert_true((n3.x - 80.0).abs() < 0.0001)
  assert_true((n3.y - 0.0).abs() < 0.0001)
  assert_true((n4.x - 40.0).abs() < 0.0001)
  assert_true((n4.y - 40.0).abs() < 0.0001)
  assert_true((n5.x - 80.0).abs() < 0.0001)
  assert_true((n5.y - 40.0).abs() < 0.0001)
  assert_true((n6.x - 0.0).abs() < 0.0001)
  assert_true((n6.y - 80.0).abs() < 0.0001)
}

///|
test "rectpacking compaction: absorb block in stack (width/height)" {
  let root = ElkNode::new("root")
  let n1 = ElkNode::with_size("n1", 178.0, 162.0)
  let n2 = ElkNode::with_size("n2", 75.0, 23.0)
  let n3 = ElkNode::with_size("n3", 75.0, 23.0)
  let n4 = ElkNode::with_size("n4", 75.0, 23.0)
  let n5 = ElkNode::with_size("n5", 75.0, 23.0)
  let n6 = ElkNode::with_size("n6", 75.0, 23.0)
  let n7 = ElkNode::with_size("n7", 75.0, 23.0)
  let n8 = ElkNode::with_size("n8", 75.0, 23.0)
  let n9 = ElkNode::with_size("n9", 75.0, 23.0)
  let n10 = ElkNode::with_size("n10", 47.0, 23.0)
  let n11 = ElkNode::with_size("n11", 47.0, 23.0)
  let n12 = ElkNode::with_size("n12", 47.0, 23.0)
  let n13 = ElkNode::with_size("n13", 47.0, 23.0)
  let n14 = ElkNode::with_size("n14", 47.0, 23.0)
  let n15 = ElkNode::with_size("n15", 47.0, 23.0)
  let n16 = ElkNode::with_size("n16", 47.0, 23.0)
  let n17 = ElkNode::with_size("n17", 47.0, 23.0)
  let n18 = ElkNode::with_size("n18", 47.0, 23.0)
  let n19 = ElkNode::with_size("n19", 47.0, 23.0)
  root.add_child(n1)
  root.add_child(n2)
  root.add_child(n3)
  root.add_child(n4)
  root.add_child(n5)
  root.add_child(n6)
  root.add_child(n7)
  root.add_child(n8)
  root.add_child(n9)
  root.add_child(n10)
  root.add_child(n11)
  root.add_child(n12)
  root.add_child(n13)
  root.add_child(n14)
  root.add_child(n15)
  root.add_child(n16)
  root.add_child(n17)
  root.add_child(n18)
  root.add_child(n19)
  elk_rect_packing_layout(root, rectpacking_target_width_options(330.0, 1.0))
  assert_true((root.width - (178.0 + 2.0 + 2.0 * 75.0)).abs() < 0.0001)
  assert_true((root.height - (162.0 + 1.0 + 23.0)).abs() < 0.0001)
}

///|
test "rectpacking compaction: compact block" {
  let root = ElkNode::new("root")
  let n1 = ElkNode::with_size("n1", 30.0, 70.0)
  let n2 = ElkNode::with_size("n2", 30.0, 30.0)
  let n3 = ElkNode::with_size("n3", 30.0, 30.0)
  let n4 = ElkNode::with_size("n4", 30.0, 30.0)
  let n5 = ElkNode::with_size("n5", 30.0, 30.0)
  root.add_child(n1)
  root.add_child(n2)
  root.add_child(n3)
  root.add_child(n4)
  root.add_child(n5)

  // Note: elk-reference sets targetWidth=190, but compaction shrinks to 110.
  elk_rect_packing_layout(root, rectpacking_target_width_options(190.0, 10.0))
  assert_true((root.width - 110.0).abs() < 0.0001)
  assert_true((root.height - 70.0).abs() < 0.0001)
  assert_true((n1.x - 0.0).abs() < 0.0001)
  assert_true((n1.y - 0.0).abs() < 0.0001)
  assert_true((n2.x - 40.0).abs() < 0.0001)
  assert_true((n2.y - 0.0).abs() < 0.0001)
  assert_true((n3.x - 80.0).abs() < 0.0001)
  assert_true((n3.y - 0.0).abs() < 0.0001)
  assert_true((n4.x - 40.0).abs() < 0.0001)
  assert_true((n4.y - 40.0).abs() < 0.0001)
  assert_true((n5.x - 80.0).abs() < 0.0001)
  assert_true((n5.y - 40.0).abs() < 0.0001)
}

///|
test "rectpacking compaction: split block" {
  let root = ElkNode::new("root")
  let n1 = ElkNode::with_size("n1", 30.0, 70.0)
  let n2 = ElkNode::with_size("n2", 30.0, 30.0)
  let n3 = ElkNode::with_size("n3", 30.0, 30.0)
  let n4 = ElkNode::with_size("n4", 30.0, 30.0)
  let n5 = ElkNode::with_size("n5", 30.0, 30.0)
  let n6 = ElkNode::with_size("n6", 30.0, 30.0)
  let n7 = ElkNode::with_size("n7", 100.0, 10.0)
  root.add_child(n1)
  root.add_child(n2)
  root.add_child(n3)
  root.add_child(n4)
  root.add_child(n5)
  root.add_child(n6)
  root.add_child(n7)
  elk_rect_packing_layout(root, rectpacking_target_width_options(110.0, 10.0))
  assert_true((root.width - 110.0).abs() < 0.0001)
  assert_true((root.height - 130.0).abs() < 0.0001)
  assert_true((n1.x - 0.0).abs() < 0.0001)
  assert_true((n1.y - 0.0).abs() < 0.0001)
  assert_true((n2.x - 40.0).abs() < 0.0001)
  assert_true((n2.y - 0.0).abs() < 0.0001)
  assert_true((n3.x - 80.0).abs() < 0.0001)
  assert_true((n3.y - 0.0).abs() < 0.0001)
  assert_true((n4.x - 40.0).abs() < 0.0001)
  assert_true((n4.y - 40.0).abs() < 0.0001)
  assert_true((n5.x - 80.0).abs() < 0.0001)
  assert_true((n5.y - 40.0).abs() < 0.0001)
  assert_true((n6.x - 0.0).abs() < 0.0001)
  assert_true((n6.y - 80.0).abs() < 0.0001)
  assert_true((n7.x - 0.0).abs() < 0.0001)
  assert_true((n7.y - 120.0).abs() < 0.0001)
}

