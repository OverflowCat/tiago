///|
/// Embedded Source Code Pro font data URLs, aligned with D2's defaults.

///|
fn concat_chunks(chunks : Array[String]) -> String {
  let sb = StringBuilder::new()
  for chunk in chunks {
    sb.write_string(chunk)
  }
  sb.to_string()
}

