///|
/// Embedded TTF font bytes used for runtime subsetting.

///|
fn decode_ttf_base64(b64 : String) -> Bytes {
  try @base64.decode(b64[:]) catch {
    _ => b""
  } noraise {
    bytes => bytes
  }
}

